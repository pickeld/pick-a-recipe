# Pick-a-Recipe — Portainer stack environment variables
# Copy to stack.env.local and fill in real values (gitignored):
#   cp portainer/stack.env portainer/stack.env.local
#
# Required for ./scripts/portainer-migrate.sh and ./scripts/portainer-deploy.sh

# App secret (required)
FLASK_SECRET_KEY=change-me-to-a-random-secret-key

# Job queue — parallel extractions (1–16, default 3)
MAX_CONCURRENT_JOBS=3

# Google SSO (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to true when served over HTTPS (recommended in production)
SESSION_COOKIE_SECURE=false

# Portainer API (required for full Portainer stack control)
# Use the same base URL you open in your browser.
# srv2/NAS: https://192.168.127.251:7441
PORTAINER_URL=
# Preferred: Portainer access token (My account → Access tokens)
PORTAINER_API_KEY=
# Optional fallback: username/password JWT auth
# PORTAINER_USER=admin
# PORTAINER_PASSWORD=
# Optional when PORTAINER_URL is an IP but TLS cert is for a hostname (NPM reverse proxy)
# PORTAINER_TLS_HOST=portainer.example.com

# Optional — auto-detected if unset
# PORTAINER_ENDPOINT_ID=1
