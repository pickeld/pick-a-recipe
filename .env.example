# Pick-a-Recipe — environment variables
# Copy to .env and fill in real values ( .env is gitignored ):
#   cp .env.example .env

# Flask session signing (required)
FLASK_SECRET_KEY=change-me-to-a-random-secret-key

# Server bind (optional)
HOST=0.0.0.0
PORT=5006
FLASK_DEBUG=false

# Job queue — parallel extractions (1–16, default 3)
MAX_CONCURRENT_JOBS=3

# Google SSO (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Set to true when served over HTTPS (recommended in production)
SESSION_COOKIE_SECURE=false
